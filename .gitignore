# Python
__pycache__/
*.py[cod]
.venv/
*.egg-info/
.pytest_cache/
.ruff_cache/
.mypy_cache/

# Node
node_modules/
dist/
.cache/
*.tsbuildinfo

# SQLite dev/test databases
*.db
*.db-journal

# Local artifact store (generated splat/quality-report outputs)
.astel-artifacts/

# Environments & secrets
.env
.env.*
!.env.example

# Data & artifacts (large binaries never in git)
data/
artifacts/
checkpoints/

# Third-party tool binaries downloaded to the box (e.g. COLMAP) — never in git;
# install path is documented in docs/setup/gpu-boxes.md
tools/

# GPU pipeline generated outputs (metrics/plys from smoke + produce + eval runs)
pipelines/gpu/out/
pipelines/gpu/out*/
pipelines/gpu/dtu_run.log

# GPU pipeline third-party code clones + downloaded model weights (never in git)
pipelines/gpu/external/
pipelines/gpu/models/
*.ply
*.spz
*.sog
*.splat
*.ckpt
*.safetensors
*.pth

# Checked-in demo assets (exceptions to the binary ban)
!apps/web/public/samples/*.ply
!apps/web/public/samples/*.spz

# Spike-local binaries & runtime junk
experiments/**/bin/
logs/

# Temporal dev-server data dir (created by `astel up -Temporal`)
.astel-temporal/

# OS / editor
Thumbs.db
.DS_Store
.vscode/
.idea/

# Claude Code local settings
.claude/settings.local.json
.claude/
node_modules/

# --- 2026-06-19: web site + engine plugins + coverage ---

# Test coverage reports (vitest / pytest-cov)
coverage/
htmlcov/

# Repo-root generated GPU scratch/showcase (per-run render PNGs, l3.ply, etc.).
# Regenerable output, not source — promote any curated asset into
# apps/web/public/samples/ instead. Delete this line if you mean to commit them.
/samples/

# Gallery splat assets served by the web app live in subfolders; re-include them
# past the global *.ply/*.spz/*.sog ban above so the gallery corpus is committed.
!apps/web/public/samples/gallery/**/*.ply
!apps/web/public/samples/gallery/**/*.spz
!apps/web/public/samples/gallery/**/*.sog

# Unity package — keep the source under plugins/unity/, drop Unity-generated dirs
plugins/unity/**/[Ll]ibrary/
plugins/unity/**/[Tt]emp/
plugins/unity/**/[Oo]bj/
plugins/unity/**/[Bb]uild/
plugins/unity/**/[Ll]ogs/
plugins/unity/**/*.csproj
plugins/unity/**/*.sln

# Unreal plugin — keep AstelPlugin/Source + *.uplugin, drop UE-generated dirs
plugins/unreal/**/[Bb]inaries/
plugins/unreal/**/[Ii]ntermediate/
plugins/unreal/**/[Ss]aved/
plugins/unreal/**/DerivedDataCache/

