{
  "name": "@astel/manifest",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "TypeScript types + reader/writer for the .astel package manifest format (mirrors docs/specs/schemas/).",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "vitest run",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "ajv": "8.20.0",
    "ajv-formats": "3.0.1"
  },
  "devDependencies": {
    "@eslint/js": "9.39.0",
    "@types/node": "^24.13.2",
    "eslint": "9.39.0",
    "globals": "16.5.0",
    "typescript": "5.9.3",
    "typescript-eslint": "8.46.0",
    "vitest": "4.1.8"
  }
}
